  color: white;
  box-shadow: 0 0 6px #f2c6d8;
}

#search input[type="text"]:focus {
  outline: none;
  border: 2px solid #f2c6d8;
  box-shadow: 0 0 6px #f2c6d8;
}

.heading a {
  color: #ffffff !important;
}

.byline a {
  color: #ffffff !important;
}

.blurb blockquote.userstuff {
  color: #ffffff !important;
}

#workskin,
.userstuff {
  color: #ffffff !important;
}

.userstuff a {
  color: #ffffff !important;
}

.javascript .filters fieldset {
